[mysqld]
# ── Replication Identity ──────────────────────
server-id = 2

# ── Relay Log ────────────────────────────────
relay_log               = relay-bin
log_bin                 = mysql-bin
log_replica_updates     = ON

# ── GTID (Master와 동일하게 설정) ──────────────
gtid_mode               = ON
enforce_gtid_consistency = ON

# ── 읽기 전용 (쓰기는 Master를 통해서만) ─────────
read_only               = ON
super_read_only         = OFF   # root/복제 계정은 쓰기 허용

# ── 문자셋 ───────────────────────────────────
character-set-server    = utf8mb4
collation-server        = utf8mb4_unicode_ci
